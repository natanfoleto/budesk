generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum UserRole {
  ROOT
  ADMIN
  EMPLOYEE
}

enum TransactionType {
  ENTRADA
  SAIDA
}

enum PaymentMethod {
  DINHEIRO
  PIX
  CARTAO
  BOLETO
  CHEQUE
  TRANSFERENCIA
}

enum AccountStatus {
  PENDENTE
  PAGA
  ATRASADA
}

enum ServiceStatus {
  ABERTO
  EM_ANDAMENTO
  FINALIZADO
  CANCELADO
}

enum VehicleType {
  CARRO
  UTILITARIO
  CAMINHONETE
  VAN
  SUV
  MOTO
  ONIBUS
  MICRO_ONIBUS
  CAMINHAO
  CAMINHAO_3_4
  CAMINHAO_TOCO
  CAMINHAO_TRUCK
  CARRETA
  BITREM
  RODOTREM
  MAQUINA
  TRATOR
  RETROESCAVADEIRA
  PA_CARREGADEIRA
  ESCAVADEIRA
  MOTONIVELADORA
  ROLO_COMPACTADOR
  REBOQUE
  SEMIRREBOQUE
  PRANCHA
  TANQUE
  COLHEITADEIRA
  PULVERIZADOR
  EMPILHADEIRA
  OUTRO
}

// Enums maintained for data integrity and backwards compatibility
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
}

enum ShirtSize {
  P
  M
  G
  GG
  XGG
}

enum ContractStatus {
  ACTIVE
  FINISHED
  TERMINATED
}

enum RHPaymentStatus {
  SIMULADO
  PENDENTE
  PAGO
  CANCELADO
}

enum RHPaymentType {
  SALARIO
  DIARIA
  COMISSAO
  BONUS
  RESCISAO
  FERIAS
  DECIMO_TERCEIRO
}

enum VacationStatus {
  PREVISTA
  APROVADA
  GOZADA
  PAGA
}

enum ThirteenthStatus {
  PENDENTE
  PARCIAL
  PAGO
}

enum AttendanceType {
  PRESENCA
  FALTA
  FALTA_JUSTIFICADA
  ATESTADO
  DECLARACAO
  AFASTAMENTO
}

enum PlantingProductionType {
  PLANTIO
  CORTE
}

enum ExpenseCategory {
  ALIMENTACAO
  COMBUSTIVEL
  EQUIPAMENTOS
  MANUTENCAO
  PECAS
  SALARIO
  SERVICOS
  OUTROS
}

// USUÁRIOS

model User {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @unique
  password  String
  role      UserRole
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  Service[]
  auditLogs AuditLog[]
  loginLogs LoginLog[]

  @@map("users")
}

// COST CENTER (NEW)

model CostCenter {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  maintenances          Maintenance[]
  rhPayments            RHPayment[]
  financialTransactions FinancialTransaction[]
  vehicleUsages         VehicleUsage[]
  accountsPayable       AccountPayable[]

  @@map("cost_centers")
}

// AUDITORIA GLOBAL

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// LOGIN LOG

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
  @@map("login_logs")
}

// CLIENTES

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  document  String? // CPF/CNPJ
  address   String?
  createdAt DateTime @default(now())

  services Service[]
  documents Document[]

  @@map("clients")
}

// FORNECEDORES

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  document  String? // CNPJ/CPF
  address   String?
  category  String?
  createdAt DateTime @default(now())

  transactions FinancialTransaction[]
  accounts     AccountPayable[]
  maintenances Maintenance[]

  @@map("suppliers")
}

// FUNCIONÁRIOS

model Employee {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  document  String?  @unique // CPF
  rg        String?
  birthDate DateTime?
  gender    String?
  shirtSize ShirtSize?
  pantsSize String?
  shoeSize  String?
  role          String?
  jobId         String?  @map("job_id")
  salaryInCents Int      @map("salary_in_cents")
  active    Boolean  @default(true)
  plantingCategory String? @map("planting_category")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  standardEntryTime String? // "08:00"
  standardExitTime  String? // "17:00"

  job               Job?     @relation(fields: [jobId], references: [id])
  advances          EmployeeAdvance[]
  transactions      FinancialTransaction[]
  employmentRecords EmploymentRecord[]
  contracts         EmployeeContract[]

  // RH Relations
  rhPayments        RHPayment[]
  salaryHistories   SalaryHistory[]
  vacations         Vacation[]
  thirteenthSalaries ThirteenthSalary[]
  timeBank          TimeBank?
  attendanceRecords AttendanceRecord[]

  plantingProductions PlantingProduction[]
  dailyWages          DailyWage[]
  driverAllocations   DriverAllocation[]
  plantingAdvances    PlantingAdvance[]

  @@map("employees")
}

model Job {
  id          String     @id @default(cuid())
  name        String
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  employees   Employee[]

  @@map("jobs")
}

model EmployeeAdvance {
  id               String   @id @default(cuid())
  employeeId       String
  amountInCents    Int      @map("amount_in_cents")
  date             DateTime
  note             String?
  payrollReference String?
  transactionId    String? @unique

  transaction FinancialTransaction? @relation(fields: [transactionId], references: [id])
  employee    Employee              @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("employee_advances")
}

model EmploymentRecord {
  id                    String    @id @default(cuid())
  employeeId            String
  admissionDate         DateTime
  terminationDate       DateTime?
  jobTitle              String
  baseSalaryInCents     Int       @map("base_salary_in_cents")
  contractType          String
  weeklyWorkload        Int?
  workRegime            String?
  isActive              Boolean   @default(true)
  hasMedicalExam        Boolean   @default(false)
  hasSignedRegistration Boolean   @default(false)
  hasSignedEpiReceipt   Boolean   @default(false)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  employee              Employee  @relation(fields: [employeeId], references: [id])

  @@map("employment_records")
}

model EmployeeContract {
  id            String         @id @default(cuid())
  employeeId    String
  type          String
  startDate     DateTime
  endDate       DateTime?
  valueInCents  Int            @map("value_in_cents")
  status        ContractStatus @default(ACTIVE)
  description   String?
  fileUrl       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  employee      Employee       @relation(fields: [employeeId], references: [id])

  @@map("employee_contracts")
}


// SERVIÇOS

model Service {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      ServiceStatus
  startDate   DateTime
  endDate     DateTime?
  clientId    String?
  createdById String
  createdAt   DateTime      @default(now())

  client       Client?                @relation(fields: [clientId], references: [id])
  createdBy    User                   @relation(fields: [createdById], references: [id])
  transactions FinancialTransaction[]
  documents    Document[]
  vehicleUsage VehicleUsage[]
  allocations  ProjectAllocation[]

  @@index([status])
  @@index([startDate])
  @@map("services")
}

// FINANCEIRO / CAIXA

model FinancialTransaction {
  id            String          @id @default(cuid())
  description   String
  type          TransactionType
  valueInCents  Int             @map("value_in_cents")
  category      ExpenseCategory
  paymentMethod PaymentMethod
  date          DateTime
  serviceId     String?
  employeeId    String?
  supplierId    String?
  costCenterId  String?
  createdAt     DateTime        @default(now())

  service    Service?  @relation(fields: [serviceId], references: [id])
  employee   Employee? @relation(fields: [employeeId], references: [id])
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])

  advance  EmployeeAdvance?
  maintenanceId String? @unique
  maintenance   Maintenance? @relation(fields: [maintenanceId], references: [id])
  rhPaymentId   String?  @unique
  rhPayment     RHPayment? @relation(fields: [rhPaymentId], references: [id])
  
  plantingExpense PlantingExpense?

  @@index([type])
  @@index([date])
  @@index([category])
  @@map("financial_transactions")
}

// CONTAS A PAGAR

model AccountPayable {
  id           String        @id @default(cuid())
  description  String
  valueInCents Int           @map("value_in_cents")
  dueDate      DateTime
  status       AccountStatus
  supplierId   String?
  costCenterId String?
  createdAt    DateTime      @default(now())

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])

  @@index([dueDate])
  @@index([status])
  @@map("accounts_payable")
}

// DOCUMENTOS

model Document {
  id          String   @id @default(cuid())
  name        String
  category    String?
  fileUrl     String
  description String?
  serviceId   String?
  clientId    String?
  vehicleId   String?
  createdAt   DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id]) 
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([category])
  @@map("documents")
}

// FROTA

model Vehicle {
  id          String      @id @default(cuid())
  plate       String
  model       String?
  brand       String?
  year        Int?
  description String?
  type        VehicleType
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())

  usages VehicleUsage[]
  documents Document[]
  maintenances Maintenance[]
  plantingExpenses PlantingExpense[]
  driverAllocations DriverAllocation[]

  @@unique([plate])
  @@map("vehicles")
}

model VehicleUsage {
  id           String  @id @default(cuid())
  vehicleId    String
  serviceId    String
  costCenterId String?
  costInCents  Int     @map("cost_in_cents")
  note         String?

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id])
  service    Service @relation(fields: [serviceId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])

  @@index([vehicleId])
  @@index([serviceId])
  @@map("vehicle_usages")
}

// MANUTENÇÃO

enum MaintenanceType {
  PREVENTIVA
  CORRETIVA
  PREDITIVA
}

enum MaintenanceStatus {
  PENDENTE
  AGENDADA
  REALIZADA
  CANCELADA
}

enum MaintenancePriority {
  BAIXA
  MEDIA
  ALTA
}

model Maintenance {
  id          String   @id @default(cuid())
  vehicleId   String
  type        MaintenanceType
  category    String   // e.g. "Troca de óleo"
  description String
  priority    MaintenancePriority
  
  // Dates & KM
  scheduledDate      DateTime
  completedDate      DateTime?
  currentKm          Int?
  nextKm             Int?
  nextDate           DateTime?
  isRecurrent        Boolean @default(false)
  intervalKm         Int?
  intervalDays       Int?
  
  // Helper
  active             Boolean @default(true) // For soft delete/archiving

  // Financial
  estimatedCost      Int     // in cents
  finalCost          Int?    // in cents
  costCenterId       String?
  supplierId         String?
  invoiceNumber      String?

  // Status
  status             MaintenanceStatus @default(PENDENTE)
  isPaid             Boolean @default(false)

  // Extras
  internalNotes      String?
  attachments        Json?
  approvalResponsible String?
  downtimeDays       Int?
  operationalImpact  String? // Could be enum or string "BAIXO", "MEDIO", "ALTO"

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicle            Vehicle @relation(fields: [vehicleId], references: [id])
  supplier           Supplier? @relation(fields: [supplierId], references: [id])
  costCenter         CostCenter? @relation(fields: [costCenterId], references: [id])
  transaction        FinancialTransaction? // 1:1 reverse relation ideally, or 1:N

  @@map("maintenances")
}

// RH — RECURSOS HUMANOS

model RHPayment {
  id                    String          @id @default(cuid())
  employeeId            String
  competenceMonth       String          // "YYYY-MM" format
  paymentType           RHPaymentType   
  baseSalaryInCents     Int             
  additionsInCents      Int             @default(0) 
  overtimeHours         Decimal         @default(0) @db.Decimal(4, 2) 
  overtimeValueInCents  Int             @default(0) 
  discountsInCents      Int             @default(0) 
  advancesValueInCents  Int             @default(0) 
  grossTotalInCents     Int             
  netTotalInCents       Int             
  status                RHPaymentStatus @default(PENDENTE)
  paymentDate           DateTime?       
  paymentMethod         PaymentMethod?  
  costCenterId          String?
  notes                 String?         
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  employee              Employee        @relation(fields: [employeeId], references: [id])
  transaction           FinancialTransaction?
  taxes                 EmployerContribution?
  allocations           ProjectAllocation[]
  costCenter            CostCenter?     @relation(fields: [costCenterId], references: [id])

  @@index([employeeId])
  @@index([competenceMonth])
  @@index([status])
  @@map("rh_payments")
}

model SalaryHistory {
  id                    String   @id @default(cuid())
  employeeId            String
  previousSalaryInCents Int  
  newSalaryInCents      Int  
  increasePercentage    Decimal  @db.Decimal(5, 2) 
  reason                String?  
  effectiveDate         DateTime 
  createdAt             DateTime @default(now())

  employee              Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("salary_histories")
}

model Vacation {
  id                     String        @id @default(cuid())
  employeeId             String
  vestingPeriodStart     DateTime      
  vestingPeriodEnd       DateTime      
  entitledDays           Int           @default(30) 
  usedDays               Int           @default(0) 
  startDate              DateTime?     
  endDate                DateTime?     
  vacationAmountInCents  Int?          
  oneThirdBonusInCents   Int?          
  status                 VacationStatus @default(PREVISTA)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  employee               Employee      @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("vacations")
}

model ThirteenthSalary {
  id                       String           @id @default(cuid())
  employeeId               String
  referenceYear            Int              
  workedMonths             Int              
  totalAmountInCents       Int              
  firstInstallmentInCents  Int?             
  secondInstallmentInCents Int?             
  firstInstallmentPaid     Boolean          @default(false) 
  secondInstallmentPaid    Boolean          @default(false) 
  status                   ThirteenthStatus @default(PENDENTE)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  employee                 Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, referenceYear])
  @@index([employeeId])
  @@map("thirteenth_salaries")
}

model TimeBank {
  id           String   @id @default(cuid())
  employeeId   String   @unique
  balanceHours Decimal  @default(0) @db.Decimal(6, 2) 
  creditHours  Decimal  @default(0) @db.Decimal(6, 2) 
  debitHours   Decimal  @default(0) @db.Decimal(6, 2) 
  updatedAt    DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("time_bank")
}

model AttendanceRecord {
  id              String         @id @default(cuid())
  employeeId      String
  date            DateTime       @db.Date 
  type            AttendanceType 
  workedHours     Decimal?       @db.Decimal(4, 2) 
  overtimeHours   Decimal?       @db.Decimal(4, 2) 
  timeBankImpact  Decimal?       @db.Decimal(4, 2) 
  notes           String?        
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employee        Employee       @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance_records")
}

model EmployerContribution {
  id                       String    @id @default(cuid())
  paymentId                String    @unique 
  companyInssInCents       Int       @default(0) 
  fgtsInCents              Int       @default(0) 
  otherTaxesInCents        Int       @default(0) 
  totalCompanyTaxesInCents Int       
  transactionId            String?   @unique
  createdAt                DateTime  @default(now())

  payment                  RHPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("employer_contributions")
}

model ProjectAllocation {
  id                     String    @id @default(cuid())
  paymentId              String    
  serviceId              String    
  allocationPercentage   Decimal   @db.Decimal(5, 2) 
  allocatedAmountInCents Int     
  createdAt              DateTime  @default(now())

  payment                RHPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  service                Service   @relation(fields: [serviceId], references: [id])

  @@index([paymentId])
  @@map("project_allocations")
}

// MÓDULO PLANTIO MANUAL

model PlantingSeason {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime?
  totalArea   Decimal?  @db.Decimal(10, 2)
  notes       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workFronts  WorkFront[]
  plantingProductions PlantingProduction[]
  dailyWages DailyWage[]
  driverAllocations DriverAllocation[]
  plantingAreas PlantingArea[]
  plantingExpenses PlantingExpense[]
  plantingAdvances PlantingAdvance[]

  @@map("planting_seasons")
}

model WorkFront {
  id          String   @id @default(cuid())
  seasonId    String
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  season      PlantingSeason @relation(fields: [seasonId], references: [id])
  plantingProductions PlantingProduction[]
  dailyWages DailyWage[]
  driverAllocations DriverAllocation[]
  plantingAreas PlantingArea[]
  plantingExpenses PlantingExpense[]
  plantingAdvances PlantingAdvance[]

  @@map("work_fronts")
}

model PlantingProduction {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  employeeId  String
  frontId     String
  seasonId    String
  type        PlantingProductionType
  meters      Decimal?  @db.Decimal(10, 2)
  meterValueInCents Int
  totalValueInCents Int
  presence    AttendanceType @default(PRESENCA)
  notes       String?
  isClosed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
  front       WorkFront @relation(fields: [frontId], references: [id])
  season      PlantingSeason @relation(fields: [seasonId], references: [id])

  @@index([date])
  @@index([employeeId])
  @@index([frontId])
  @@map("planting_productions")
}

model DailyWage {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  employeeId  String
  frontId     String
  seasonId    String
  valueInCents Int
  presence    AttendanceType @default(PRESENCA)
  notes       String?
  isClosed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
  front       WorkFront @relation(fields: [frontId], references: [id])
  season      PlantingSeason @relation(fields: [seasonId], references: [id])

  @@index([date])
  @@index([employeeId])
  @@index([frontId])
  @@map("daily_wages")
}

model DriverAllocation {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  employeeId  String
  vehicleId   String?
  frontId     String
  seasonId    String
  valueInCents Int      // Copied from category at creation time
  notes       String?
  isClosed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  front       WorkFront @relation(fields: [frontId], references: [id])
  season      PlantingSeason @relation(fields: [seasonId], references: [id])

  @@index([date])
  @@index([employeeId])
  @@index([vehicleId])
  @@map("driver_allocations")
}

model PlantingArea {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  frontId     String
  seasonId    String
  workedArea  Decimal  @db.Decimal(10, 2)
  hectares    Decimal  @db.Decimal(10, 2)
  notes       String?
  isClosed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  front       WorkFront @relation(fields: [frontId], references: [id])
  season      PlantingSeason @relation(fields: [seasonId], references: [id])

  @@index([date])
  @@index([frontId])
  @@map("planting_areas")
}

model PlantingExpense {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  frontId     String
  seasonId    String
  category    ExpenseCategory
  description String
  quantity    Decimal?  @db.Decimal(10, 2)
  unitValueInCents Int?
  totalValueInCents Int
  vehicleId   String?
  transactionId String? @unique
  notes       String?
  isClosed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  front       WorkFront @relation(fields: [frontId], references: [id])
  season      PlantingSeason @relation(fields: [seasonId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  transaction FinancialTransaction? @relation(fields: [transactionId], references: [id])

  @@index([date])
  @@index([category])
  @@map("planting_expenses")
}

model PlantingAdvance {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  employeeId      String
  frontId         String
  seasonId        String
  valueInCents    Int
  notes           String?
  discountInCurrentFortnight Boolean @default(true)
  isClosed        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee       @relation(fields: [employeeId], references: [id])
  front    WorkFront      @relation(fields: [frontId], references: [id])
  season   PlantingSeason @relation(fields: [seasonId], references: [id])

  @@index([date])
  @@index([employeeId])
  @@index([frontId])
  @@map("planting_advances")
}

model PlantingParameter {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "valor_metro_plantio", "preco_diesel", "valor_metro_corte"
  value       String   // String to handle decimal or simple values
  description String?
  updatedAt   DateTime @updatedAt

  @@map("planting_parameters")
}
